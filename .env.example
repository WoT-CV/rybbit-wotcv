# Domain and URL Configuration
DOMAIN_NAME=demo.rybbit.com
BASE_URL="https://${DOMAIN_NAME}"

# Authentication and Security
BETTER_AUTH_SECRET=insecure-secret
DISABLE_SIGNUP=false

# Webserver Configuration
# Set to false to disable the built-in Caddy webserver
USE_WEBSERVER=true
# Host port mappings - these control how services are exposed
# Format: "host_binding:container_port" or "port:container_port"
HOST_BACKEND_PORT=127.0.0.1:3001
HOST_CLIENT_PORT=127.0.0.1:3002

# ClickHouse Database Configuration
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=frog

# PostgreSQL Database Configuration
POSTGRES_DB=analytics
POSTGRES_USER=frog
POSTGRES_PASSWORD=frog

# Resolve anonymous browser IDs to identified accounts through a ClickHouse
# dictionary backed by PostgreSQL. Set false only for emergency rollback.
IDENTITY_RESOLUTION_V2=true
# Merge a recent anonymous recording into the identified session after login.
# Set to 0 for an emergency rollback; values above 120000 are capped.
SESSION_IDENTITY_CONTINUATION_GRACE_MS=30000

# External Service Tokens (optional)
MAPBOX_TOKEN=

# Google OAuth (optional)
# Enables Google login and Google Search Console when both credentials are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# GitHub OAuth login (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare Turnstile protection for authentication forms (optional)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Transactional email through Resend (optional)
# EMAIL_FROM is required on self-hosted deployments and must use a verified sender domain.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
# Weekly reports remain opt-in on self-hosted deployments.
ENABLE_WEEKLY_REPORTS=false

# Cloudflare R2 replay storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rybbit

# Twilio SMS notifications for uptime monitoring (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
